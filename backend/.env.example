# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/careersaathi

# JWT Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# LLM API Keys
